<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Coding Blogs</title>
    <link
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css"
      rel="stylesheet"
      integrity="sha384-9ndCyUaIbzAi2FUVXJi0CjmCapSmO7SnpJef0486qhLnuZ2cdeRhO02iuK6FUUVM"
      crossorigin="anonymous"
    />
  </head>
  <body>
    <nav class="navbar navbar-expand-lg navbar-dark bg-dark">
      <div class="container-fluid">
        <a class="navbar-brand" href="/">Coding Blog</a>
        <button
          class="navbar-toggler"
          type="button"
          data-bs-toggle="collapse"
          data-bs-target="#navbarSupportedContent"
          aria-controls="navbarSupportedContent"
          aria-expanded="false"
          aria-label="Toggle navigation"
        >
          <span class="navbar-toggler-icon"></span>
        </button>
        <div class="collapse navbar-collapse" id="navbarSupportedContent">
          <ul class="navbar-nav me-auto mb-2 mb-lg-0">
            <li class="nav-item">
              <a class="nav-link active" aria-current="page" href="/">Home</a>
            </li>
          </ul>
        </div>
      </div>
    </nav>
    <div class="container my-2">
      <h1>Add Blog</h1>

      <!-- Display success message -->
      <% if (locals.success && success === true) { %>
        <div class="alert alert-success" role="alert">
          validation successful!
        </div>
      <% } %>

      <!-- Display error messages -->
      <% if (locals.errors && errors && Object.keys(errors).length > 0) { %>
        <div class="alert alert-danger" role="alert">
          <ul class="mb-0">
            <% if (errors.title) { %>
              <li><%= errors.title %></li>
            <% } %>
            <% if (errors.description) { %>
              <li><%= errors.description %></li>
            <% } %>
            <% if (errors.image) { %>
              <li><%= errors.image %></li>
            <% } %>
          </ul>
        </div>
      <% } %>

      <form action="/addblog" method="post" class="p-5">
        <div class="form-group">
          <label for="title">Title</label>
          <input
            name="title"
            type="text"
            class="form-control <%= locals.errors && errors.title ? 'is-invalid' : '' %>"
            id="title"
            placeholder="Enter Blog Title"
            value="<%= locals.blogData && blogData.title ? blogData.title : '' %>"
          />
          <% if (locals.errors && errors.title) { %>
            <div class="invalid-feedback">
              <%= errors.title %>
            </div>
          <% } %>
        </div>
        <div class="form-group">
          <label for="description">Description</label>
          <input
            name="description"
            type="text"
            class="form-control <%= locals.errors && errors.description ? 'is-invalid' : '' %>"
            id="description"
            placeholder="Enter Blog Description"
            value="<%= locals.blogData && blogData.description ? blogData.description : '' %>"
          />
          <% if (locals.errors && errors.description) { %>
            <div class="invalid-feedback">
              <%= errors.description %>
            </div>
          <% } %>
        </div>
        <div class="form-group">
          <label for="image">Image</label>
          <input
            type="text"
            name="image"
            class="form-control <%= locals.errors && errors.image ? 'is-invalid' : '' %>"
            id="image"
            placeholder="Enter Blog Image Url"
            value="<%= locals.blogData && blogData.image ? blogData.image : '' %>"
          />
          <% if (locals.errors && errors.image) { %>
            <div class="invalid-feedback">
              <%= errors.image %>
            </div>
          <% } %>
        </div>
        <button type="submit" class="btn btn-primary mt-2">Submit</button>
      </form>
    </div>
    <script
      src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"
      integrity="sha384-geWF76RCwLtnZ8qwWowPQNguL3RmwHVBC9FhGdlKrxdiJJigb/j/68SIy3Te4Bkz"
      crossorigin="anonymous"
    ></script>
  </body>
</html>